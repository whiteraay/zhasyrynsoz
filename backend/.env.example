# Copy this to .env and fill in your values
# Backend settings

# Path to the downloaded FastText .vec file
VECTORS_PATH=./data/wiki.kk.vec

# Path for the numpy cache (auto-created after first load)
CACHE_PATH=./data/kk_vectors.npz

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://yourdomain.com

# Server port (used by uvicorn)
PORT=8000
